---
import type { ProcessedItem } from '../lib/types';

interface Props {
  items?: ProcessedItem[];
}

const { items = [] } = Astro.props;

const displayDate = items.length > 0 && items[0].snapshot_date
  ? new Date(items[0].snapshot_date + 'T00:00:00')
  : new Date();

const year = displayDate.getFullYear();
const month = String(displayDate.getMonth() + 1).padStart(2, '0');
const day = String(displayDate.getDate()).padStart(2, '0');

const ahaScore = items.length > 0
  ? (items.reduce((sum, item) => sum + (item.aha_index || 0), 0) / items.length * 100).toFixed(1)
  : '0.0';
---

<header class="masthead">
  <div class="masthead-inner">
    <div class="masthead-logo">
      <a href="/" class="logo" style="text-decoration: none;" data-astro-reload>
        <svg class="logo-icon" viewBox="0 0 26 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="stroke: rgba(28,26,23,0.5);">
          <polyline points="1,17 8,7 14,12 20,3 25,6" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span class="logo-text">Amazing<span>Index</span></span>
      </a>
    </div>

    <div class="masthead-title">
      <span class="masthead-tagline">AMAZINGINDEX.COM</span>
      <span class="masthead-subtitle">每日 AI 简报</span>
    </div>

    <div class="masthead-meta">
      <div class="aha-score-mobile">
        <span class="score-trigger">{ahaScore}</span>
      </div>
      <div class="masthead-vol">
        VOL. {year}.{month}<br/>
        {year}.{month}.{day}
      </div>
    </div>
  </div>
</header>
