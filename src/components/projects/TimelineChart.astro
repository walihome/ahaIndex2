---
/**
 * TimelineChart: SVG 折线图 + 面积填充
 * Props:
 *   timeline: { date: string; aha: number }[]
 */
interface Props {
  timeline: { date: string; aha: number }[];
}

const { timeline } = Astro.props;

if (timeline.length === 0) return;

const width = 640;
const height = 200;
const padding = { top: 20, right: 20, bottom: 30, left: 40 };
const chartW = width - padding.left - padding.right;
const chartH = height - padding.top - padding.bottom;

const dates = timeline.map(t => t.date);
const scores = timeline.map(t => t.aha);

const maxScore = Math.max(...scores, 100);
const minScore = 0;

function x(i: number): number {
  return padding.left + (i / Math.max(dates.length - 1, 1)) * chartW;
}

function y(score: number): number {
  return padding.top + chartH - ((score - minScore) / (maxScore - minScore)) * chartH;
}

// 折线路径
const linePath = timeline
  .map((t, i) => `${i === 0 ? 'M' : 'L'} ${x(i).toFixed(1)} ${y(t.aha).toFixed(1)}`)
  .join(' ');

// 面积填充路径
const areaPath = `${linePath} L ${x(timeline.length - 1).toFixed(1)} ${y(0).toFixed(1)} L ${x(0).toFixed(1)} ${y(0).toFixed(1)} Z`;

// Y 轴刻度
const yTicks = [0, 25, 50, 75, 100];
---

<div class="timeline-chart">
  <svg class="timeline-svg" viewBox={`0 0 ${width} ${height}`} preserveAspectRatio="xMidYMid meet">
    {/* 网格线 */}
    {yTicks.map(v => (
      <line
        x1={padding.left}
        y1={y(v)}
        x2={width - padding.right}
        y2={y(v)}
        stroke="rgba(26,22,18,0.08)"
        stroke-width="1"
      />
    ))}

    {/* Y 轴标签 */}
    {yTicks.map(v => (
      <text
        x={padding.left - 8}
        y={y(v)}
        text-anchor="end"
        dominant-baseline="middle"
        fill="#888"
        font-size="9"
        font-family="'DM Mono', monospace"
      >
        {v}
      </text>
    ))}

    {/* 面积填充 */}
    <path d={areaPath} fill="rgba(192,57,43,0.08)" />

    {/* 折线 */}
    <path d={linePath} fill="none" stroke="#c0392b" stroke-width="2" stroke-linejoin="round" />

    {/* 数据点 */}
    {timeline.map((t, i) => (
      <circle
        cx={x(i)}
        cy={y(t.aha)}
        r="3"
        fill="#c0392b"
        stroke="#f0ebe0"
        stroke-width="1.5"
      />
    ))}

    {/* X 轴标签（首尾 + 中间） */}
    {dates.length > 0 && (
      <text x={x(0)} y={height - 6} text-anchor="start" fill="#888" font-size="8" font-family="'DM Mono', monospace">
        {dates[0]}
      </text>
    )}
    {dates.length > 2 && (
      <text x={x(Math.floor(dates.length / 2))} y={height - 6} text-anchor="middle" fill="#888" font-size="8" font-family="'DM Mono', monospace">
        {dates[Math.floor(dates.length / 2)]}
      </text>
    )}
    {dates.length > 1 && (
      <text x={x(dates.length - 1)} y={height - 6} text-anchor="end" fill="#888" font-size="8" font-family="'DM Mono', monospace">
        {dates[dates.length - 1]}
      </text>
    )}
  </svg>
</div>
