---
interface Props {
  categories?: string[];
  selectedCategory?: string;
  date?: string;
}

const { categories = [], selectedCategory = '全部', date } = Astro.props;

const displayDate = date ? new Date(date + 'T00:00:00') : new Date();
const year = displayDate.getFullYear();
const month = String(displayDate.getMonth() + 1).padStart(2, '0');
const weekDay = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'][displayDate.getDay()];
---

<nav class="nav-bar">
  <div class="nav-inner">
    <div class="nav-tabs" id="nav-tabs">
      {categories.map(category => (
        <button
          class={`nav-tab ${selectedCategory === category ? 'active' : ''}`}
          data-category={category}
        >
          {category.toUpperCase() === 'ENTERTAINMENT' ? (
            <>
              <span class="cat-desktop">{category}</span>
              <span class="cat-mobile">ENT</span>
            </>
          ) : category}
        </button>
      ))}
    </div>
    <div class="nav-date">VOL. {year}.{month} &nbsp;·&nbsp; {weekDay}</div>
  </div>
</nav>
