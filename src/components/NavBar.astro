---
interface Props {
  categories?: string[];
  selectedCategory?: string;
}

const { categories = [], selectedCategory = '全部' } = Astro.props;

const now = new Date();
const year = now.getFullYear();
const month = String(now.getMonth() + 1).padStart(2, '0');
const weekDay = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'][now.getDay()];
---

<nav class="nav-bar">
  <div class="nav-inner">
    <div class="nav-tabs" id="nav-tabs">
      {categories.map(category => (
        <button
          class={`nav-tab ${selectedCategory === category ? 'active' : ''}`}
          data-category={category}
        >
          {category.toUpperCase() === 'ENTERTAINMENT' ? (
            <>
              <span class="cat-desktop">{category}</span>
              <span class="cat-mobile">ENT</span>
            </>
          ) : category}
        </button>
      ))}
    </div>
    <div class="nav-date">VOL. {year}.{month} &nbsp;·&nbsp; {weekDay}</div>
  </div>
</nav>
