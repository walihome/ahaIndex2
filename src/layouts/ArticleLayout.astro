---
import BaseLayout from './BaseLayout.astro';
import DailyPage from '../components/DailyPage.astro';
import type { ProcessedItem, DailyArchive, GlobalStats } from '../lib/types';
import { getDailyArchiveByDate } from '../lib/data';

interface Props {
  item: ProcessedItem;
  date: string;
  items: ProcessedItem[];
  stats: GlobalStats;
  days: DailyArchive[];
  categories: string[];
}

const { item, date, items, stats, days, categories } = Astro.props;
const dailyArchive = await getDailyArchiveByDate(date);

const title = (item.processed_title || item.title || '无标题') + ' | AmazingIndex';
const desc = (item.summary || '').slice(0, 150);
const articleUrl = `https://www.amazingindex.com/article/${item.processed_item_id}`;

let extra: any = {};
if (typeof item.extra === 'string') {
  try { extra = JSON.parse(item.extra); } catch {}
} else if (item.extra) {
  extra = item.extra;
}

let rawMetrics: any = {};
if (typeof item.raw_metrics === 'string') {
  try { rawMetrics = JSON.parse(item.raw_metrics); } catch {}
} else if (item.raw_metrics) {
  rawMetrics = item.raw_metrics;
}

const paragraphs = (item.expert_insight || '').split('\n').filter((p: string) => p.trim());
const dateStr = item.snapshot_date ? item.snapshot_date.replace(/-/g, '.') : '';
const backUrl = `/daily/${date}`;

const enrichment = extra?.enrichment || {};
const sentimentLabel: Record<string, string> = { positive: '正面', mixed: '意见分歧', negative: '负面' };
const sentimentClass: Record<string, string> = { positive: 'positive', mixed: 'mixed', negative: 'negative' };
const maturityLabel: Record<string, string> = { production: 'Production', beta: 'Beta', experimental: 'Experimental' };
const maturityClass: Record<string, string> = { production: 'production', beta: 'beta', experimental: 'experimental' };

const tweets: any[] = extra?.tweets || [];

function formatNumber(num: number) {
  if (num >= 1000) return (num / 1000).toFixed(1) + 'k';
  return String(num);
}
---

<BaseLayout
  title={title}
  description={desc}
  canonicalUrl={articleUrl}
  ogType="article"
  ogTitle={item.processed_title || item.title || '无标题'}
  ogDescription={desc}
  ogUrl={articleUrl}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": item.processed_title || item.title || '无标题',
    "description": desc,
    "url": articleUrl,
    "datePublished": item.created_at || item.snapshot_date,
    "publisher": { "@type": "Organization", "name": "AmazingIndex" }
  }}
>
  <div class="article-page-bg" aria-hidden="true">
    <DailyPage items={items} stats={stats} days={days} dailyArchive={dailyArchive} date={date} categories={categories} showArchiveBanner={true} />
  </div>

  <div class="backdrop" data-back-url={backUrl}>
    <div class="modal" transition:animate="slide">
      <div class="drag-handle"></div>

      <div class="modal-header">
        <div class="modal-topbar">
          <div class="tag-row">
            {item.content_type && <span class="tag">#{item.content_type.toUpperCase()}</span>}
          </div>
          <button class="close-btn" aria-label="Close">×</button>
        </div>

        <h1 class="modal-title">{item.processed_title || item.title || '无标题'}</h1>

        <div class="modal-meta">
          {item.source_name && <span class="meta-text">{item.source_name.toUpperCase()}</span>}
          {item.source_name?.includes('GitHub') && rawMetrics.stars !== undefined && (
            <span class="meta-text"><span class="meta-star-icon">★</span> {formatNumber(rawMetrics.stars)}</span>
          )}
          {item.source_name?.includes('GitHub') && rawMetrics.forks !== undefined && (
            <span class="meta-text">Fork {formatNumber(rawMetrics.forks)}</span>
          )}
          {item.source_name?.includes('GitHub') && extra.language && (
            <span class="meta-text">{extra.language}</span>
          )}
          {(item.source_name?.includes('HackerNews')) && rawMetrics.score !== undefined && (
            <span class="meta-text">▲ {formatNumber(rawMetrics.score)}</span>
          )}
          {(item.source_name?.includes('HackerNews')) && rawMetrics.comments !== undefined && (
            <span class="meta-text">💬 {formatNumber(rawMetrics.comments)}</span>
          )}
          {(item.source_name?.includes('Twitter') || item.source_name?.includes('X')) && rawMetrics.tweet_count !== undefined && (
            <span class="meta-text">{formatNumber(rawMetrics.tweet_count)} tweets</span>
          )}
          {dateStr && <span class="meta-date">{dateStr}</span>}
        </div>
      </div>

      <div class="modal-body">
        {item.summary && <p class="summary">{item.summary}</p>}

        {extra?.description && (
          <p class="modal-description-en">{extra.description}</p>
        )}

        {item.content_type === 'repo' && extra?.readme_images?.length > 0 && (
          <div style="margin-bottom: 24px;" class="repo-cover-wrap">
            <img
              src={extra.readme_images[0]}
              alt="封面图"
              loading="lazy"
              width="800"
              height="400"
              style="width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border);"
              onerror="this.parentElement.style.display='none'"
            />
          </div>
        )}

        {(() => {
          const videoUrl = extra?.media_urls?.find((u: string) => /\.(mp4|webm|mov)(\?|#|$)/i.test(u));
          const imageUrl = extra?.media_urls?.find((u: string) => /\.(png|jpg|jpeg|webp|gif)(\?|#|$)/i.test(u));
          if (videoUrl) return (
            <div style="margin-bottom: 24px;">
              <video src={videoUrl} poster={extra.thumbnail_url || undefined} controls muted playsinline preload="metadata" style="width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border); background: #000;" />
            </div>
          );
          if (imageUrl) return (
            <div style="margin-bottom: 24px;">
              <img src={imageUrl} alt={item.processed_title || '配图'} loading="lazy" width="800" height="450" style="width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border);" onerror="this.parentElement.style.display='none'" />
            </div>
          );
          if (extra?.thumbnail_url) return (
            <div style="margin-bottom: 24px;">
              <img src={extra.thumbnail_url} alt={item.processed_title || '配图'} loading="lazy" width="800" height="450" style="width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border);" onerror="this.parentElement.style.display='none'" />
            </div>
          );
          return null;
        })()}

        <div class="insight-block">
          <div class="insight-text">
            <em style="display: block; margin-bottom: 8px;">Editor's Note:</em>
            {paragraphs.length > 0
              ? paragraphs.map((p: string) => <p class="insight-paragraph">{p}</p>)
              : <p class="insight-paragraph">暂无专家洞察</p>
            }
          </div>
        </div>

        {item.content_type === 'repo' && extra?.star_history_url && (
          <div style="margin-bottom: 24px;" class="star-history-wrap">
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 8px; font-weight: 600;">STAR HISTORY</div>
            <img
              src={extra.star_history_url}
              alt="Star History"
              loading="lazy"
              width="800"
              height="400"
              style="width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border);"
              onerror="this.parentElement.style.display='none'"
            />
          </div>
        )}

        {/* 社区反馈区块 */}
        {enrichment.sentiment && (
          <div class="enrichment-section">
            <div class="enrichment-title">社区反馈</div>
            <div class="enrichment-badges">
              <span class={`enrichment-badge ${sentimentClass[enrichment.sentiment] || ''}`}>
                {sentimentLabel[enrichment.sentiment] || enrichment.sentiment}
              </span>
              {enrichment.comment_count && (
                <span class="enrichment-badge neutral">💬 {enrichment.comment_count} 条评论</span>
              )}
            </div>
            {enrichment.core_debate && (
              <p class="enrichment-text">核心争论：{enrichment.core_debate}</p>
            )}
            {enrichment.top_comments_raw?.length > 0 && (
              <div class="enrichment-comments">
                {enrichment.top_comments_raw.map((c: any) => (
                  <div class="enrichment-comment">
                    <div class="enrichment-comment-header">
                      <span class="enrichment-comment-author">{c.author}</span>
                      {c.points > 0 && <span class="enrichment-comment-points">▲ {c.points}</span>}
                    </div>
                    <p class="enrichment-comment-text">{c.text}</p>
                  </div>
                ))}
              </div>
            )}
            {enrichment.alternatives?.length > 0 && (
              <div class="enrichment-tags">
                <span class="enrichment-tag-label">替代方案：</span>
                {enrichment.alternatives.map((alt: string) => (
                  <span class="enrichment-tag">{alt}</span>
                ))}
              </div>
            )}
          </div>
        )}

        {/* 生态分析区块 */}
        {enrichment.maturity && (
          <div class="enrichment-section">
            <div class="enrichment-title">生态分析</div>
            <div class="enrichment-badges">
              <span class={`enrichment-badge ${maturityClass[enrichment.maturity] || ''}`}>
                {maturityLabel[enrichment.maturity] || enrichment.maturity}
              </span>
            </div>
            {enrichment.ecosystem_position && (
              <p class="enrichment-text">{enrichment.ecosystem_position}</p>
            )}
            {enrichment.unique_value && (
              <p class="enrichment-text">独特价值：{enrichment.unique_value}</p>
            )}
            {enrichment.competitors?.length > 0 && (
              <div class="enrichment-competitors">
                <div class="enrichment-tag-label">竞品：</div>
                {enrichment.competitors.map((c: any) => (
                  <div class="enrichment-competitor">
                    <a href={`https://github.com/${c.name}`} target="_blank" rel="noopener noreferrer" class="enrichment-competitor-name">
                      {c.name}
                    </a>
                    {c.stars > 0 && <span class="enrichment-competitor-stars">★ {formatNumber(c.stars)}</span>}
                    {c.comparison && <span class="enrichment-competitor-desc">{c.comparison}</span>}
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* 相关内容区块 */}
        {enrichment.related_articles?.length > 0 && (
          <div class="enrichment-section">
            <div class="enrichment-title">相关内容</div>
            <div class="enrichment-articles">
              {enrichment.related_articles.map((a: any) => (
                <a href={a.url} target="_blank" rel="noopener noreferrer" class="enrichment-article">
                  <span class="enrichment-article-title">{a.title}</span>
                  {a.snippet && <span class="enrichment-article-snippet">{a.snippet}</span>}
                </a>
              ))}
            </div>
            {enrichment.key_discussions?.length > 0 && (
              <div class="enrichment-discussions">
                <div class="enrichment-tag-label">社区讨论：</div>
                {enrichment.key_discussions.map((d: any) => (
                  <a href={d.url} target="_blank" rel="noopener noreferrer" class="enrichment-discussion">
                    <span class="enrichment-discussion-source">{d.source}</span>
                    <span class="enrichment-discussion-summary">{d.summary}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        )}

        {/* Twitter 推文列表 */}
        {item.content_type === 'tweet_digest' && tweets.length > 0 && (
          <div class="enrichment-section">
            <div class="enrichment-title">推文合集 · {tweets.length} 条</div>
            <div class="enrichment-tweets">
              {tweets.map((t: any) => (
                <div class="enrichment-tweet">
                  <div class="enrichment-tweet-header">
                    <span class="enrichment-tweet-author">@{t.author}</span>
                    <span class="enrichment-tweet-stats">
                      {t.likes > 0 && <span>❤️ {formatNumber(t.likes)}</span>}
                      {t.retweets > 0 && <span>🔁 {formatNumber(t.retweets)}</span>}
                    </span>
                  </div>
                  <p class="enrichment-tweet-text">{t.text}</p>
                  {t.url && (
                    <a href={t.url} target="_blank" rel="noopener noreferrer" class="enrichment-tweet-link">查看原文 →</a>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="modal-footer">
        <button class="close-footer-btn" aria-label="Close">×</button>
        {(item.original_url || item.url) && (
          <a
            href={item.original_url || item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            data-item-id={item.processed_item_id}
            data-snapshot-date={item.snapshot_date}
            data-event="click_original"
          >
            查看原文 →
          </a>
        )}
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const backdrop = document.querySelector('.backdrop');
      const closeBtns = document.querySelectorAll('.close-btn, .close-footer-btn');
      if (!backdrop) return;

      function goBack() {
        const backUrl = backdrop.getAttribute('data-back-url');
        if (document.referrer && (document.referrer.includes('/daily/') || document.referrer.includes('amazingindex.com'))) {
          history.back();
        } else if (backUrl) {
          window.location.href = backUrl;
        }
      }

      backdrop.addEventListener('click', (e) => {
        if (e.target === backdrop) goBack();
      });
      closeBtns.forEach((btn) => btn.addEventListener('click', goBack));
    });
  </script>
</BaseLayout>
