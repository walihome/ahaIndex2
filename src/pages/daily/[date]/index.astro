---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DailyPage from '../../../components/DailyPage.astro';
import { getAllDates, getItemsByDate, getGlobalStats, getDailyArchives } from '../../../lib/data';

export async function getStaticPaths() {
  const dates = await getAllDates();
  return dates.map(date => ({ params: { date } }));
}

const { date } = Astro.params;
const items = await getItemsByDate(date!);
const stats = await getGlobalStats();

const now = new Date();
const days = await getDailyArchives(now.getFullYear(), now.getMonth() + 1);

const categories = ['全部', ...Array.from(new Set(items.map(item => item.category).filter(Boolean) as string[]))];

const pageTitle = `AmazingIndex · ${date} AI 行业精选简报`;
const pageDesc = `AmazingIndex ${date} 每日 AI 行业精选简报。基于多维度量化算法，为您筛选当日最具价值的 AI 行业动态与创新洞察。`;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl={`https://www.amazingindex.com/daily/${date}`}
  ogTitle={pageTitle}
  ogDescription={pageDesc}
  ogUrl={`https://www.amazingindex.com/daily/${date}`}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": pageDesc,
    "url": `https://www.amazingindex.com/daily/${date}`
  }}
>
  <DailyPage items={items} stats={stats} days={days} date={date} categories={categories} />
</BaseLayout>
