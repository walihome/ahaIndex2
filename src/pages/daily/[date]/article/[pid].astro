---
import ArticleLayout from '../../../../layouts/ArticleLayout.astro';
import { getAllDates, getItemsByDate } from '../../../../lib/data';

export async function getStaticPaths() {
  const dates = await getAllDates();
  const paths = [];
  for (const date of dates) {
    const items = await getItemsByDate(date);
    for (const item of items) {
      if (item.processed_item_id) {
        paths.push({
          params: { date, pid: item.processed_item_id },
          props: { item, date },
        });
      }
    }
  }
  return paths;
}

const { item, date } = Astro.props;
---

<ArticleLayout item={item} date={date} />
