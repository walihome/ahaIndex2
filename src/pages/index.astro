---
import BaseLayout from '../layouts/BaseLayout.astro';
import DailyPage from '../components/DailyPage.astro';
import { getLatestDate, getItemsByDate, getGlobalStats, getDailyArchives } from '../lib/data';

const latestDate = await getLatestDate();
const items = latestDate ? await getItemsByDate(latestDate) : [];
const stats = await getGlobalStats();

const now = new Date();
const days = await getDailyArchives(now.getFullYear(), now.getMonth() + 1);

const categories = ['全部', ...Array.from(new Set(items.map(item => item.category).filter(Boolean) as string[]))];
---

<BaseLayout>
  <DailyPage items={items} stats={stats} days={days} categories={categories} heading="每日 AI 行业精选简报" />
</BaseLayout>
